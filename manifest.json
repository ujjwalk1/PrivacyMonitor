{
  "manifest_version": 2,
  "name": "Privacy & Security Monitor",
  "version": "1.1",
  "description": "Monitor password strength, security headers, data breaches, and insecure forms",

  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "scripting",
    "webRequest",
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"]
    }
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Privacy Monitor"
  },

  "applications": {
    "gecko": {
      "id": "privacy-monitor@example.com"
    }
  }
}
